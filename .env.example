# ---- Postgres ----
POSTGRES_USER=seolab
POSTGRES_PASSWORD=seolab
POSTGRES_DB=seolab
POSTGRES_URL=postgresql://seolab:seolab@db:5432/seolab

# ---- Redis ----
REDIS_URL=redis://redis:6379/0

# ---- App ----
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=production
LOG_LEVEL=INFO
HTTP_PORT=80
CORS_ORIGINS=http://localhost,http://localhost:5173

# ---- Bootstrap admin (used ONLY when DB has zero users — first boot) ----
# After login, change the password in the UI (Settings → Account); you can
# then blank these out. They're ignored at startup if any user already exists.
# Password must be >= 8 chars.
SEOLAB_ADMIN_EMAIL=
SEOLAB_ADMIN_PASSWORD=

# ---- DataForSEO (https://app.dataforseo.com) ----
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ---- Anthropic Claude ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Google OAuth (Search Console) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost/api/gsc/oauth/callback

# ---- Google PageSpeed Insights (https://developers.google.com/speed/docs/insights/v5/get-started) ----
GOOGLE_PAGESPEED_API_KEY=

# ---- Open PageRank (https://www.domcop.com/openpagerank/) ----
OPEN_PAGERANK_API_KEY=

# ---- Crawler ----
CRAWLER_USER_AGENT=SEOLabBot/1.0 (+https://seolab.local)
CRAWLER_MAX_PAGES=500
CRAWLER_RATE_LIMIT_RPS=1.0
